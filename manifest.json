{
  "manifest_version": 3,
  "name": "LLM Debate: Mesa Redonda",
  "version": "1.1",
  "description": "Triangulação usando abas abertas do Gemini, ChatGPT e Perplexity.",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://www.perplexity.ai/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
